# =============================================================================
# CallForce — Environment Variables
# =============================================================================
# Legend:
#   REQUIRED-PROD  — must be set for production/staging deployments
#   OPTIONAL       — enhances functionality but not required
#   TEST-MODE      — defaults work for local development; change for production
# =============================================================================

# --- Core Application ---
APP_ENV=local                                      # TEST-MODE: local | development | staging | production
API_HOST=0.0.0.0                                   # OPTIONAL
API_PORT=8000                                      # OPTIONAL
WEB_PORT=3000                                      # OPTIONAL
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000  # REQUIRED-PROD: set to your domain(s)

# --- Database ---
DATABASE_URL=postgresql://callforce:callforce@localhost:5432/callforce  # REQUIRED-PROD
STORE_BACKEND=sqlalchemy                           # TEST-MODE: sqlalchemy (production) | memory (tests only)

# --- Auth / Security ---
ACCESS_TOKEN_SECRET=change-me-local-development-secret  # REQUIRED-PROD: generate a strong 64+ char secret
ACCESS_TOKEN_TTL_MINUTES=15                        # OPTIONAL
REFRESH_TOKEN_TTL_DAYS=30                          # OPTIONAL
JWT_SECRET=change-me-local-only                    # REQUIRED-PROD
ENCRYPTION_KEY=change-me-local-only                # REQUIRED-PROD: used for at-rest encryption of integration tokens
WEBHOOK_SIGNING_SECRET=change-me-local-only        # REQUIRED-PROD

# --- Redis ---
REDIS_URL=redis://localhost:6379/0                 # REQUIRED-PROD
RATE_LIMIT_ENABLED=true                            # OPTIONAL
RATE_LIMIT_STORAGE_URI=                            # OPTIONAL: defaults to REDIS_URL

# --- Vector Database (Qdrant) ---
QDRANT_URL=http://localhost:6333                    # REQUIRED-PROD: empty = :memory: in local only
QDRANT_COLLECTION_NAME=callforce_knowledge_chunks  # OPTIONAL
QDRANT_VECTOR_SIZE=384                             # OPTIONAL: update when switching embedding model
QDRANT_DISTANCE=Cosine                             # OPTIONAL

# --- LLM ---
LLM_PROVIDER=auto                                 # OPTIONAL: auto | openai | vllm | mock
LLM_MAX_TOKENS=1024                               # OPTIONAL
LLM_TEMPERATURE=0.3                               # OPTIONAL
LLM_TIMEOUT_SECONDS=30                            # OPTIONAL
OPENAI_API_KEY=                                    # REQUIRED-PROD (if using OpenAI): sk-...
OPENAI_FAST_MODEL=gpt-4o-mini                     # OPTIONAL
OPENAI_SMART_MODEL=gpt-4o                         # OPTIONAL
VLLM_BASE_URL=http://localhost:8001/v1             # OPTIONAL: set if using local vLLM
VLLM_API_KEY=not-needed                           # OPTIONAL
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct              # OPTIONAL

# --- Speech (STT/TTS) ---
STT_MODEL_PATH=/models/whisper                    # OPTIONAL: local Whisper model path
TTS_MODEL_PATH=/models/tts                        # OPTIONAL: local TTS model path

# --- Telephony: Twilio ---
TWILIO_ACCOUNT_SID=                               # REQUIRED-PROD (if using Twilio)
TWILIO_AUTH_TOKEN=                                 # REQUIRED-PROD (if using Twilio)
TWILIO_PHONE_NUMBER=                              # REQUIRED-PROD (if using Twilio)

# --- Telephony: Asterisk ---
ASTERISK_ARI_URL=http://localhost:8088/ari         # OPTIONAL
ASTERISK_ARI_USERNAME=                             # OPTIONAL
ASTERISK_ARI_PASSWORD=                             # OPTIONAL

# --- Messaging Channels ---
TELEGRAM_BOT_TOKEN=                               # REQUIRED-PROD (if using Telegram)
# VK and WhatsApp are configured per-tenant via settings API

# --- Payments ---
YOOKASSA_SHOP_ID=                                 # REQUIRED-PROD (if using payments)
YOOKASSA_SECRET_KEY=                              # REQUIRED-PROD (if using payments)

# --- CRM/Orders: iiko ---
IIKO_API_LOGIN=                                   # OPTIONAL
IIKO_API_PASSWORD=                                # OPTIONAL

# --- Object Storage (MinIO/S3) ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000      # OPTIONAL
OBJECT_STORAGE_BUCKET=callforce-local              # OPTIONAL
OBJECT_STORAGE_ACCESS_KEY=minioadmin               # OPTIONAL
OBJECT_STORAGE_SECRET_KEY=minioadmin               # OPTIONAL

# --- SMTP (Email) ---
SMTP_HOST=                                        # REQUIRED-PROD (if using email verify/reset)
SMTP_PORT=587                                     # OPTIONAL
SMTP_USER=                                        # REQUIRED-PROD (if using SMTP)
SMTP_PASSWORD=                                    # REQUIRED-PROD (if using SMTP)
SMTP_FROM=noreply@callforce.local                 # REQUIRED-PROD: set to your domain
SMTP_USE_TLS=true                                 # OPTIONAL

# --- Observability ---
SENTRY_DSN=                                       # OPTIONAL: Sentry error tracking
OTEL_ENABLED=false                                # OPTIONAL: OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317 # OPTIONAL
GRAFANA_PASSWORD=admin                            # TEST-MODE

# --- Multi-tenant ---
ALLOW_LEGACY_TENANT_HEADER=true                   # TEST-MODE: false in production
SEED_DEMO_DATA=true                               # TEST-MODE: false in production
DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001  # TEST-MODE

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000          # REQUIRED-PROD: public API URL
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001  # TEST-MODE
NEXT_PUBLIC_WIDGET_AGENT_ID=389a4f13-05d3-5860-af9f-69bd9ce2493a  # TEST-MODE
API_PUBLIC_URL=http://localhost:8000               # REQUIRED-PROD

# --- Production Deployment ---
APP_DOMAIN=your-domain.com                        # REQUIRED-PROD
API_DOMAIN=api.your-domain.com                    # REQUIRED-PROD
GRAFANA_DOMAIN=grafana.your-domain.com            # OPTIONAL
ACME_EMAIL=admin@your-domain.com                  # REQUIRED-PROD (for TLS certs)
